{
  "name": "la-caleta",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:la-caleta": "node dist/la-caleta/server/server.mjs",
    "build:pages": "ng build --configuration production --base-href \"/La-Caleta/\"",
